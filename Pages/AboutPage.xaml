<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NicoleToolbox.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NicoleToolbox"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <TextBlock Text="关于" FontSize="50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25,25,0,0"/>
        <ScrollViewer Margin="0,120,0,0">
            <Grid>
                <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="25,10,0,0" Padding="8" CornerRadius="8">
                    <StackPanel Orientation="Vertical" Spacing="8">
                        <TextBlock Text="尼可工具箱" FontSize="40" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                        <TextBlock Text="一个原神工具箱，集成了一些在线工具，基于 WinUI 3 制作" FontSize="30" HorizontalAlignment="Left" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <GridView VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,300,25,0">
                    <Button Click="GitHub" Width="250" Height="50">
                        <Grid Width="230" Height="30">
                            <FontIcon Glyph="&#xE8F1;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBlock Text="GitHub主页" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Button>
                    <Button Click="Issue" Width="250" Height="50">
                        <Grid Width="230" Height="30">
                            <FontIcon Glyph="&#xE7BA;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBlock Text="报告问题" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Button>
                    <Button Click="Contributors" Width="250" Height="50">
                        <Grid Width="230" Height="30">
                            <FontIcon Glyph="&#xE716;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBlock Text="贡献者" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Button>
                    <Button Click="Website" Width="250" Height="50">
                        <Grid Width="230" Height="30">
                            <FontIcon Glyph="&#xE774;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBlock Text="官方网站" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Button>
                </GridView>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
