<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NicoleToolbox.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NicoleToolbox"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" RequestedTheme="Light" Background="LightGray">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/about_background.png" Stretch="UniformToFill" AlignmentX="Center" AlignmentY="Center"/>
        </Grid.Background>
        <TextBlock Text="关于" FontSize="50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25,25,0,0"/>
        <Image Source="/Assets/logo.png" Width="128" Height="128" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,300"/>
        <Border Background="#CCFFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="8" CornerRadius="8">
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="尼可工具箱" FontSize="30" HorizontalAlignment="Center"/>
                <TextBlock Text="一个原神工具箱，集成了一些在线工具，基于 WinUI 3 制作" FontSize="20" HorizontalAlignment="Center"/>
                <TextBlock Text="版本：Dev" FontSize="20" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        <StackPanel Orientation="Vertical" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,100">
            <Button Click="GitHub" Width="250" Height="40">
                <Grid Width="220">
                    <FontIcon Glyph="&#xE8F1;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="GitHub主页" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Button>
            <Button Click="Issue" Width="250" Height="40">
                <Grid Width="220">
                    <FontIcon Glyph="&#xE7BA;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="报告问题" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Button>
            <Button Click="Contributors" Width="250" Height="40">
                <Grid Width="220">
                    <FontIcon Glyph="&#xE716;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="贡献者" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Button>
        </StackPanel>
    </Grid>
</Page>
