<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NicoleToolbox.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NicoleToolbox"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <TextBlock Text="关于" FontSize="50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25,25,0,0"/>
        <Image Source="/Assets/Logo.ico" Width="64" Height="64" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-300,0,0"/>
        <TextBlock Text="尼可工具箱" FontSize="30" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-100,0,0"/>
        <TextBlock Text="一个原神工具箱，集成了一些在线工具，基于 WinUI 3 制作" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0"/>
        <StackPanel Orientation="Vertical" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,100">
            <Button Click="GitHub" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Height="40">
                <Grid Width="220">
                    <FontIcon Glyph="&#xE8F1;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="GitHub" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Button>
            <Button Click="Issue" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Height="40">
                <Grid Width="220">
                    <FontIcon Glyph="&#xE7BA;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="报告问题" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Button>
            <Button Click="Contributors" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250" Height="40">
                <Grid Width="220">
                    <FontIcon Glyph="&#xE716;" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="贡献者" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Button>
        </StackPanel>
    </Grid>
</Page>
