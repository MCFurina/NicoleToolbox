<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NicoleToolbox.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NicoleToolbox"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Image Source="/Assets/Logo.ico" Width="64" Height="64" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-300,0,0"/>
        <TextBlock Text="关于" FontSize="50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25,25,0,0"/>
        <TextBlock Text="尼可工具箱" FontSize="30" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-100,0,0"/>
        <TextBlock Text="提供一些原神实用工具" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0"/>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,100,0,0">
            <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/MCFurina/NicoleToolbox/" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <HyperlinkButton Content="报告问题" NavigateUri="https://github.com/MCFurina/NicoleToolbox/issues" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
