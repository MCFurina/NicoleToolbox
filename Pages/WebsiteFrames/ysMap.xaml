<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NicoleToolbox.Pages.WebsiteFrames.ysMap"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NicoleToolbox.Pages.WebsiteFrames"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Border VerticalAlignment="Top" HorizontalAlignment="Stretch" Height="50">
            <Grid>
                <Button Click="Back" HorizontalAlignment="Left" VerticalAlignment="Center" Height="50">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE72B;" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="返回百宝箱" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="原神地图工具" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Click="Reload" HorizontalAlignment="Right" VerticalAlignment="Center" Height="50">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE72C;" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="刷新地图" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <WebView2 x:Name="WebView2" Source="https://act.mihoyo.com/ys/app/interactive-map/index.html" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,52,0,0"/>
    </Grid>
</Page>
