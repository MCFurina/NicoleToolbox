                </Grid>
            </HyperlinkButton>
            <HyperlinkButton Width="400" Height="100" NavigateUri="https://baike.mihoyo.com/ys/obc">
                <Grid>
                    <TextBlock Text="观测枢" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-20,0,0"/>
