<Window
    x:Class="NicoleToolbox.VideoResourcesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="视频资源库">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid x:Name="AppTitleBar" Height="32" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <Image Source="/Assets/Logo.ico" Width="16" Height="16" Margin="0,0,12,0" />
                <TextBlock Text="视频资源库"/>
            </StackPanel>
        </Grid>

        <!-- 标签栏 -->
        <controls:SelectorBar Grid.Row="1" x:Name="VideoSelectorBar"
                             SelectionChanged="OnSelectorBarSelectionChanged"
                             Margin="12,8">
            <controls:SelectorBarItem Text="角色视频" Tag="Character" IsSelected="True"/>
            <controls:SelectorBarItem Text="过场动画" Tag="Cutscene"/>
        </controls:SelectorBar>

        <!-- 内容容器（两个内容区自动切换显示） -->
        <Grid Grid.Row="2">

            <!-- 角色视频 -->
            <Grid x:Name="CharacterPanel" Visibility="Visible">
                <ProgressBar IsIndeterminate="True" VerticalAlignment="Top" 
                             Visibility="{x:Bind ToVisibility(IsLoading), Mode=OneWay}"/>
                <GridView ItemsSource="{x:Bind CharacterVideos}"
                          SelectionMode="None"
                          Padding="12">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="240" Height="200" Margin="8" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Image Source="{Binding Cover}" Stretch="UniformToFill" VerticalAlignment="Top" Height="135"/>
                                <TextBlock Grid.Row="1" Text="{Binding Title}" TextWrapping="Wrap" MaxLines="2" Margin="8,4" FontSize="12" FontWeight="Bold"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,8,0" Spacing="8">
                                    <Button Content="播放" Click="OnPlayClick" Tag="{Binding}" FontSize="10" Padding="8,4" Height="28"/>
                                    <Button Content="下载" Click="OnDownloadClick" Tag="{Binding}" FontSize="10" Padding="8,4" Height="28"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

            <!-- 过场动画 -->
            <Grid x:Name="CutscenePanel" Visibility="Collapsed">
                <ProgressBar IsIndeterminate="True" VerticalAlignment="Top" 
                             Visibility="{x:Bind ToVisibility(IsLoading), Mode=OneWay}"/>
                <GridView ItemsSource="{x:Bind CutsceneVideos}"
                          SelectionMode="None"
                          Padding="12">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="240" Height="200" Margin="8" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Image Source="{Binding Cover}" Stretch="UniformToFill" VerticalAlignment="Top" Height="135"/>
                                <TextBlock Grid.Row="1" Text="{Binding Title}" TextWrapping="Wrap" MaxLines="2" Margin="8,4" FontSize="12" FontWeight="Bold"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,8,0" Spacing="8">
                                    <Button Content="播放" Click="OnPlayClick" Tag="{Binding}" FontSize="10" Padding="8,4" Height="28"/>
                                    <Button Content="下载" Click="OnDownloadClick" Tag="{Binding}" FontSize="10" Padding="8,4" Height="28"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

            <!-- 爬虫WebView2 -->
            <controls:WebView2 x:Name="CrawlerWebView" Width="0" Height="0" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
    